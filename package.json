{
  "name": "muse",
  "version": "2.11.4",
  "description": "an unofficial fork of a self-hosted Discord music bot",
  "repository": "git@github.com:NanashiTheNameless/muse.git",
  "author": "NanashiTheNameless <Nanashi@NamelessNanashi.dev>",
  "contributors": [
    "Max Isom <hi@maxisom.me>"
  ],
  "license": "MIT",
  "private": true,
  "types": "dts/types",
  "type": "module",
  "engines": {
    "node": ">=24.15.0"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "yarn run typecheck",
    "start": "npm run env:set-database-url -- tsx src/scripts/migrate-and-start.ts",
    "cache:clear-key-value": "npm run env:set-database-url tsx src/scripts/cache-clear-key-value.ts",
    "dev": "npm run env:set-database-url -- tsx watch src/scripts/start.ts",
    "migrations:generate": "npm run prisma:with-env migrate dev",
    "migrations:run": "npm run prisma:with-env migrate deploy",
    "prisma:with-env": "npm run env:set-database-url prisma",
    "prisma:generate": "prisma generate",
    "env:set-database-url": "tsx src/scripts/run-with-database-url.ts",
    "release": "release-it",
    "build": "tsc",
    "postinstall": "patch-package"
  },
  "devDependencies": {
    "@types/bluebird": "^3.5.42",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/fs-capacitor": "^8.0.2",
    "@types/ms": "^2.1.0",
    "@types/node": "^25.9.1",
    "@types/node-emoji": "^2.1.0",
    "@types/validator": "^13.15.10",
    "@types/ws": "8.18.1",
    "prisma": "^7.8.0",
    "release-it": "^20.0.1",
    "type-fest": "^5.6.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@discordjs/builders": "^1.14.1",
    "@discordjs/opus": "^0.10.0",
    "@discordjs/rest": "^2.6.1",
    "@discordjs/voice": "^0.19.2",
    "@distube/ytdl-core": "^4.16.12",
    "@distube/ytsr": "^2.0.4",
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0",
    "@inversifyjs/core": "^10.0.1",
    "@noble/ciphers": "^2.2.0",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@stablelib/xchacha20poly1305": "^2.0.1",
    "@types/libsodium-wrappers": "^0.8.2",
    "array-shuffle": "^4.1.0",
    "better-sqlite3": "^12.10.0",
    "delay": "^7.0.0",
    "discord-api-types": "^0.38.47",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "execa": "^9.6.1",
    "fluent-ffmpeg": "^2.1.3",
    "fs-capacitor": "^8.0.0",
    "get-youtube-id": "^1.0.1",
    "got": "^15.0.5",
    "hasha": "^7.0.0",
    "inversify": "^8.1.0",
    "iso8601-duration": "^2.1.3",
    "libsodium-wrappers": "^0.8.4",
    "make-dir": "^5.1.0",
    "node-emoji": "^2.2.0",
    "opusscript": "^0.1.1",
    "ora": "^9.4.0",
    "p-event": "^7.1.0",
    "p-limit": "^7.3.0",
    "p-queue": "^9.3.0",
    "p-retry": "^8.0.0",
    "pagination.djs": "^4.0.18",
    "parse-duration": "^2.1.6",
    "patch-package": "^8.0.1",
    "postinstall-postinstall": "^2.1.0",
    "read-pkg": "^10.1.0",
    "reflect-metadata": "^0.2.2",
    "sodium-native": "^5.1.0",
    "sponsorblock-api": "^0.2.4",
    "sync-fetch": "^0.6.0",
    "tsx": "^4.22.3",
    "xbytes": "^1.9.1",
    "ytsr": "^3.8.4"
  },
  "resolutions": {
    "@types/ws": "8.18.1"
  },
  "packageManager": "yarn@4.14.1"
}
